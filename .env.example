# Site URL (optional, for SEO)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin dashboard (/login) — Insights & Registrants
ADMIN_EMAIL=admin@jskills.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# MongoDB — enrollments saved to jskills database → users collection
# Prefer mongodb+srv from Atlas. If you see querySrv ECONNREFUSED locally, use the
# "standard connection string" from Atlas (mongodb://... not mongodb+srv://).
DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority

# Email (enrollment + contact developer) — sends to asriidev@gmail.com
RESEND_API_KEY=re_your_api_key_here
DEVELOPER_EMAIL=asriidev@gmail.com
# Set to true to send welcome emails to registrants (off by default)
# SEND_REGISTRANT_EMAIL=true

# Optional: use a verified domain sender (recommended for production)
# RESEND_FROM_EMAIL=JSkills <noreply@yourdomain.com>
